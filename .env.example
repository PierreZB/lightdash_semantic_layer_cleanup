# This file is used to configure the environment for the semantic layer cleanup script.
# Rename this file to .env and fill in the values below.

# --- Instructions ---
# Provide the full command required to run `lightdash` commands in your environment.
# Each command should handle activating your virtual environment (if necessary) and then
# executing the lightdash command.

# === DOWNLOAD COMMAND ===
# Used by script 1 to download the latest project state from your Lightdash instance.
# Example for Conda:
# DOWNLOAD_COMMAND="conda run -n dbt lightdash download --all"
# Example for Python venv (Linux/macOS):
# DOWNLOAD_COMMAND="source /path/to/your/venv/bin/activate && lightdash download --all"
# Example for Python venv (Windows):
# DOWNLOAD_COMMAND="C:\\path\\to\\your\\venv\\Scripts\\activate.bat && lightdash download --all"
DOWNLOAD_COMMAND="eval \"$(conda shell.bash hook)\" && conda activate dbt && lightdash download"


# === VALIDATION COMMAND ===
# Used by script 4 to validate changes to the YAML files.
# Example for Conda:
# QUICK_VALIDATION_COMMAND="conda run -n dbt lightdash validate --skip-dbt-compile"
# Example for Python venv (Linux/macOS):
# QUICK_VALIDATION_COMMAND="source /path/to/your/venv/bin/activate && lightdash validate --skip-dbt-compile"
# Example for Python venv (Windows):
# QUICK_VALIDATION_COMMAND="C:\\path\\to\\your\\venv\\Scripts\\activate.bat && lightdash validate --skip-dbt-compile"
QUICK_VALIDATION_COMMAND="eval \"$(conda shell.bash hook)\" && conda activate dbt && lightdash validate --skip-dbt-compile"

# === INITIAL VALIDATION COMMAND ===
# Similar to QUICK_VALIDATION_COMMAND but used by script 0 to validate the initial state of the project before any changes are made.
INITIAL_VALIDATION_COMMAND="eval \"$(conda shell.bash hook)\" && conda activate dbt && lightdash validate"